---
import { getCollection } from "astro:content";
import { t, localePath, type Lang } from "../i18n/content";

const { lang } = Astro.props as { lang: Lang };
const tr = t(lang).blog;

const collection = lang === "de" ? "blog" : "blog_en";
const posts = (await getCollection(collection))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const fmt = (d: Date) =>
  d.toLocaleDateString(lang === "de" ? "de-DE" : "en-GB", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
---

{
  posts.length > 0 && (
    <section class="py-20 lg:py-28">
      <div class="container-px">
        <div class="flex flex-wrap items-end justify-between gap-4" data-reveal>
          <div class="max-w-2xl">
            <p class="eyebrow">{tr.eyebrow}</p>
            <h2 class="mt-4 text-3xl text-stone-ink sm:text-4xl">{tr.title}</h2>
            <p class="mt-4 text-stone-soft">{tr.text}</p>
          </div>
          <a href={localePath(lang, "blog")} class="btn-ghost">{tr.all}</a>
        </div>

        <div class="mt-12 grid gap-6 md:grid-cols-3">
          {posts.map((post) => (
            <a
              href={localePath(lang, `blog/${post.id}`)}
              class="group flex flex-col overflow-hidden rounded-[1.5rem] border border-rose-100 bg-white/60 transition hover:-translate-y-1 hover:shadow-lg hover:shadow-rose-100"
              data-reveal
            >
              <div class="aspect-[16/10] overflow-hidden bg-rose-100">
                {post.data.cover && (
                  <img
                    src={post.data.cover}
                    alt={post.data.title}
                    loading="lazy"
                    class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                  />
                )}
              </div>
              <div class="flex flex-1 flex-col p-6">
                <div class="flex items-center gap-3 text-xs text-stone-soft">
                  <span class="rounded-full bg-rose-100 px-3 py-1 font-medium text-rose-500">
                    {post.data.category}
                  </span>
                  <time>{fmt(post.data.pubDate)}</time>
                </div>
                <h3 class="mt-3 text-xl text-stone-ink transition group-hover:text-rose-500">
                  {post.data.title}
                </h3>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-stone-soft">
                  {post.data.description}
                </p>
                <span class="mt-4 text-sm font-medium text-rose-500">{tr.readMore} →</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )
}
