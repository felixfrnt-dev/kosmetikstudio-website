---
import { services, t, type Lang } from "../i18n/content";
const { lang } = Astro.props as { lang: Lang };
const tr = t(lang).services;
---

<section id="services" class="scroll-mt-24 py-20 lg:py-28">
  <div class="container-px">
    <div class="mx-auto max-w-2xl text-center" data-reveal>
      <p class="eyebrow">{tr.eyebrow}</p>
      <h2 class="mt-4 text-3xl text-stone-ink sm:text-4xl">{tr.title}</h2>
      <p class="mt-4 text-stone-soft">{tr.text}</p>
    </div>

    <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        services.map((s) => (
          <article
            class="group flex flex-col rounded-[1.5rem] border border-rose-100 bg-white/60 p-7 transition hover:-translate-y-1 hover:border-rose-200 hover:shadow-lg hover:shadow-rose-100"
            data-reveal
          >
            <span class="flex h-12 w-12 items-center justify-center rounded-full bg-rose-100 text-2xl text-rose-500 transition group-hover:bg-rose-400 group-hover:text-white">
              {s.icon}
            </span>
            <h3 class="mt-5 text-xl text-stone-ink">{s[lang].title}</h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-stone-soft">{s[lang].text}</p>
            <div class="mt-6 flex items-center justify-between border-t border-rose-100 pt-4 text-sm">
              <span class="font-semibold text-rose-500">{s.price}</span>
              <span class="text-stone-soft">{s.duration}</span>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
