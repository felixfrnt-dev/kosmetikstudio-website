---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { studio, type Lang } from "../i18n/content";

interface Props {
  lang: Lang;
  title: string;
  description?: string;
}

const { lang, title, description } = Astro.props;
const fullTitle = `${title} · ${studio.name}`;
const desc =
  description ??
  (lang === "de"
    ? "Kosmetikstudio für Gesichtsbehandlungen, Wimpern, Brauen & Permanent Make-up. Jetzt Termin anfragen."
    : "Beauty studio for facials, lashes, brows & permanent make-up. Request your appointment today.");
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#f0b3b0" />

    <!-- Schriften -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Poppins:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Header lang={lang} />
    <main>
      <slot />
    </main>
    <Footer lang={lang} />

    <!-- GSAP-Animationen (gebündelt) -->
    <script>
      import "../scripts/animations.ts";
    </script>
  </body>
</html>
