---
import { getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { t, localePath } from "../../../i18n/content";

const lang = "en" as const;
const tr = t(lang).blog;

const posts = (await getCollection("blog_en", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const fmt = (d: Date) =>
  d.toLocaleDateString("en-GB", { year: "numeric", month: "long", day: "numeric" });
---

<BaseLayout lang={lang} title={tr.title}>
  <section class="container-px py-16 lg:py-24">
    <div class="mx-auto max-w-2xl text-center">
      <p class="eyebrow">{tr.eyebrow}</p>
      <h1 class="mt-4 text-4xl text-stone-ink sm:text-5xl">{tr.title}</h1>
      <p class="mt-4 text-stone-soft">{tr.text}</p>
    </div>

    <div class="mt-14 grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {
        posts.map((post) => (
          <a
            href={localePath(lang, `blog/${post.id}`)}
            class="group flex flex-col overflow-hidden rounded-[1.5rem] border border-rose-100 bg-white/60 transition hover:-translate-y-1 hover:shadow-lg hover:shadow-rose-100"
          >
            <div class="aspect-[16/10] overflow-hidden bg-rose-100">
              {post.data.cover && (
                <img
                  src={post.data.cover}
                  alt={post.data.title}
                  loading="lazy"
                  class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
                />
              )}
            </div>
            <div class="flex flex-1 flex-col p-6">
              <div class="flex items-center gap-3 text-xs text-stone-soft">
                <span class="rounded-full bg-rose-100 px-3 py-1 font-medium text-rose-500">
                  {post.data.category}
                </span>
                <time>{fmt(post.data.pubDate)}</time>
              </div>
              <h2 class="mt-3 text-xl text-stone-ink transition group-hover:text-rose-500">
                {post.data.title}
              </h2>
              <p class="mt-2 flex-1 text-sm leading-relaxed text-stone-soft">
                {post.data.description}
              </p>
              <span class="mt-4 text-sm font-medium text-rose-500">{tr.readMore} →</span>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>
